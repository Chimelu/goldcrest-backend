# Database (see src/models/index.ts)
# DATABASE_URL=postgres://...
# Or:
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=goldcrest
# DB_USER=postgres
# DB_PASSWORD=

JWT_SECRET=change-me-in-production

# Zoho Mail — use an app-specific password if your account requires it
ZOHO_EMAIL=you@yourdomain.com
ZOHO_PASSWORD=

# Optional (defaults work for many Zoho accounts)
# ZOHO_SMTP_HOST=smtp.zoho.com
# ZOHO_SMTP_PORT=465
# For some regions / TLS:
# ZOHO_SMTP_HOST=smtp.zoho.eu
# ZOHO_SMTP_PORT=587

# Set to false to skip Sequelize alter on startup (production migrations recommended)
# DB_SYNC_ALTER=false
